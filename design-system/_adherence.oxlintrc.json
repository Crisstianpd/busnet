{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/foundations/**",
              "components/navigation/**",
              "components/surfaces/**",
              "components/transit/**",
              "ui_kits/fleet-dashboard/**",
              "ui_kits/passenger-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Manrope, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|color|icon|size|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, color, icon, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:route|premium|live|success|warning|danger|neutral)$/]",
        "message": "<Badge> variant must be one of 'route' | 'premium' | 'live' | 'success' | 'warning' | 'danger' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomSheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:snap|onSnapChange|heights|header|showHandle|style|key|ref|className|style|children)$/]",
        "message": "<BottomSheet> doesn't accept that prop. Declared props: snap, onSnapChange, heights, header, showHandle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BusMarker'] > JSXAttribute > JSXIdentifier[name!=/^(?:route|color|bearing|state|size|onClick|style|key|ref|className|style|children)$/]",
        "message": "<BusMarker> doesn't accept that prop. Declared props: route, color, bearing, state, size, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BusMarker'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:moving|stopped|selected)$/]",
        "message": "<BusMarker> state must be one of 'moving' | 'stopped' | 'selected'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|fullWidth|disabled|loading|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, fullWidth, disabled, loading, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|icon|delta|deltaDirection|tone|style|key|ref|className|style|children)$/]",
        "message": "<KpiCard> doesn't accept that prop. Declared props: label, value, unit, icon, delta, deltaDirection, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='deltaDirection'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<KpiCard> deltaDirection must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|amber|info|red|neutral)$/]",
        "message": "<KpiCard> tone must be one of 'green' | 'amber' | 'info' | 'red' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapPin'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|label|size|style|key|ref|className|style|children)$/]",
        "message": "<MapPin> doesn't accept that prop. Declared props: variant, label, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapPin'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:origin|destination|stop)$/]",
        "message": "<MapPin> variant must be one of 'origin' | 'destination' | 'stop'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|onClear|placeholder|leadingIcon|trailingIcon|size|autoFocus|style|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: value, onChange, onClear, placeholder, leadingIcon, trailingIcon, size, autoFocus, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<SearchInput> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|height|radius|style|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: width, height, radius, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|tone|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Spinner> doesn't accept that prop. Declared props: size, tone, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|white|amber|muted)$/]",
        "message": "<Spinner> tone must be one of 'green' | 'white' | 'amber' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|title|detail|route|routeColor|duration|active|last|style|key|ref|className|style|children)$/]",
        "message": "<StepItem> doesn't accept that prop. Declared props: type, title, detail, route, routeColor, duration, active, last, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepItem'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:walk|bus|transfer|origin|destination)$/]",
        "message": "<StepItem> type must be one of 'walk' | 'bus' | 'transfer' | 'origin' | 'destination'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBarItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabBarItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:cells|columns|head|selected|entering|onClick|style|key|ref|className|style|children)$/]",
        "message": "<TableRow> doesn't accept that prop. Declared props: cells, columns, head, selected, entering, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|message|tone|icon|action|onClose|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: title, message, tone, icon, action, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|success|warning|danger)$/]",
        "message": "<Toast> tone must be one of 'info' | 'success' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TripLeg'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|route|color|minutes|key|ref|className|style|children)$/]",
        "message": "<TripLeg> doesn't accept that prop. Declared props: type, route, color, minutes."
      },
      {
        "selector": "JSXOpeningElement[name.name='TripLeg'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:bus|walk)$/]",
        "message": "<TripLeg> type must be one of 'bus' | 'walk'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
